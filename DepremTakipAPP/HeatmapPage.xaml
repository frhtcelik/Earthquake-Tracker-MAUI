<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:maps="clr-namespace:Microsoft.Maui.Controls.Maps;assembly=Microsoft.Maui.Controls.Maps"
             x:Class="DepremTakipAPP.HeatmapPage"
             Title="Sismik Isı Haritası">

    <Grid>
        <maps:Map x:Name="HeatmapMap" MapType="Hybrid" />

        <Frame VerticalOptions="Start" HorizontalOptions="Center" 
               Margin="0,20,0,0" Padding="15" 
               BackgroundColor="White" Opacity="0.9" CornerRadius="10">
            <VerticalStackLayout Spacing="5">
                <Label Text="Son 100 Deprem Isı Haritası" FontAttributes="Bold" HorizontalOptions="Center"/>
                <Label Text="Renkler şiddete göre değişir (Kırmızı = Şiddetli)" FontSize="12" TextColor="Gray" HorizontalOptions="Center"/>
            </VerticalStackLayout>
        </Frame>
    </Grid>

</ContentPage>