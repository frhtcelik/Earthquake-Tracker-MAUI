<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:viewModels="clr-namespace:DepremTakipAPP.ViewModels"
             x:Class="DepremTakipAPP.NotificationSettingsPage"
             Title="Kisilestirme"
             BackgroundColor="#F5F6FA">

    <ContentPage.BindingContext>
        <viewModels:NotificationSettingsViewModel />
    </ContentPage.BindingContext>

    <Grid>
        <ScrollView>
            <VerticalStackLayout Padding="20" Spacing="15">

                <Label Text="{Binding MinMagnitudeLabel}" FontSize="Large" HorizontalOptions="Center" TextColor="Black" />
                <Stepper Minimum="1.0" Maximum="10.0" Increment="0.5" Value="{Binding MinMagnitude}" HorizontalOptions="Center" />

                <Grid ColumnDefinitions="*,Auto" ColumnSpacing="10" Margin="0,10,0,0">
                    <Picker Grid.Column="0" 
                            Title="Takip etmek için bir şehir seçin..." 
                            ItemsSource="{Binding AllCities}" 
                            SelectedItem="{Binding SelectedCityFromPicker}" 
                            BackgroundColor="#F5F6FA"
                            TextColor="Black"/>
                    <Button Grid.Column="1" Text="Ekle" Command="{Binding AddCityCommand}" />
                </Grid>

                <Button Text="Test Bildirimi Gönder" Command="{Binding SendTestNotificationCommand}" Margin="0,10" />

                <Label Text="Takip Edilen Şehirler:" FontSize="Medium" Margin="0,20,0,0" FontAttributes="Bold" TextColor="Black"/>

                <CollectionView ItemsSource="{Binding FollowedCities}">
                    <CollectionView.ItemTemplate>
                        <DataTemplate>
                            <Frame Padding="10" Margin="0,5" BorderColor="LightGray" CornerRadius="5" BackgroundColor="#F5F6FA">
                                <Grid ColumnDefinitions="*,Auto">
                                    <Label Grid.Column="0" Text="{Binding .}" VerticalOptions="Center" TextColor="Black" />
                                    <Button Grid.Column="1" Text="Sil" 
                                            Command="{Binding Source={RelativeSource AncestorType={x:Type viewModels:NotificationSettingsViewModel}}, Path=RemoveCityCommand}" 
                                            CommandParameter="{Binding .}" 
                                            BackgroundColor="Red" TextColor="White" HeightRequest="40" CornerRadius="5"/>
                                </Grid>
                            </Frame>
                        </DataTemplate>
                    </CollectionView.ItemTemplate>
                </CollectionView>
            </VerticalStackLayout>
        </ScrollView>

        <BoxView BackgroundColor="Black" Opacity="0.5" IsVisible="{Binding IsMenuOpen}">
            <BoxView.GestureRecognizers>
                <TapGestureRecognizer Command="{Binding ToggleMenuCommand}" />
            </BoxView.GestureRecognizers>
        </BoxView>

        <Frame IsVisible="{Binding IsMenuOpen}"
               VerticalOptions="End" HorizontalOptions="FillAndExpand"
               Margin="20, 0, 20, 90" 
               CornerRadius="5" BorderColor="LightGray"
               BackgroundColor="White" Padding="15" HasShadow="True">

            <VerticalStackLayout Spacing="10">
                <Label Text="Acil Durum Kişileri (Maks 3)" HorizontalOptions="Center" FontSize="Medium" FontAttributes="Bold" TextColor="Black"/>

                <VerticalStackLayout BindableLayout.ItemsSource="{Binding AcilKisiler}" Spacing="5">
                    <BindableLayout.ItemTemplate>
                        <DataTemplate>
                            <Frame Padding="10" Margin="0,2" BorderColor="LightGray" CornerRadius="5">
                                <Grid ColumnDefinitions="*, Auto">
                                    <Label Grid.Column="0" Text="{Binding Gorunum}" VerticalOptions="Center" TextColor="Black" />
                                    <Button Grid.Column="1" Text="Sil" 
                                            Command="{Binding Source={RelativeSource AncestorType={x:Type viewModels:NotificationSettingsViewModel}}, Path=RemoveKisiCommand}"
                                            CommandParameter="{Binding .}"
                                            BackgroundColor="Red" TextColor="White" 
                                            HeightRequest="40" CornerRadius="5"/>
                                </Grid>
                            </Frame>
                        </DataTemplate>
                    </BindableLayout.ItemTemplate>
                </VerticalStackLayout>

                <Button Text="Yeni Kişi Ekle" Command="{Binding KisiSecCommand}" HeightRequest="40" CornerRadius="5" Margin="0,10,0,0"/>
                <Button Text="Güvendeyim Mesajı Gönder" Command="{Binding GuvendeyimCommand}" TextColor="White" FontAttributes="Bold" HeightRequest="40" CornerRadius="5" BackgroundColor="Green"/>

                <Button Text="Güvende Değilim (Konum Gönder)" Command="{Binding GuvendeDegilimCommand}" TextColor="White" FontAttributes="Bold" HeightRequest="40" CornerRadius="5" BackgroundColor="DarkRed" Margin="0,5,0,0"/>
            </VerticalStackLayout>
        </Frame>

        <Button Text="Acil" 
                FontAttributes="Bold" FontSize="16"
                Command="{Binding ToggleMenuCommand}"
                BackgroundColor="Red" TextColor="White"
                CornerRadius="35" WidthRequest="70" HeightRequest="70"
                VerticalOptions="End" HorizontalOptions="End" Margin="20">
            <Button.Shadow>
                <Shadow Brush="Black" Offset="0,4" Opacity="0.3" Radius="5"/>
            </Button.Shadow>
        </Button>

    </Grid>
</ContentPage>